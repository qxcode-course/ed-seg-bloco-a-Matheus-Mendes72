            "content": "package main\nimport \"fmt\"\n\nfunc quadrado(n int) int {\n    if n == 1 {\n        fmt.Println(\"1^2 = 1\")\n        return 1\n    }\n\n    fmt.Printf(\"%d^2 = %d^2 + 2*%d + 1 = ?\\n\", n, (n-1), (n-1))\n\n    // quadrado_anterior := quadrado(n-1)\n    resultado := quadrado(n-1) + 2*(n-1) + 1\n    fmt.Printf(\"%d^2 = %d^2 + 2*%d + 1 = %d\\n\", n, (n-1), (n-1), resultado)\n\n    return resultado\n}\n\nfunc main() {\n    var n int\n    fmt.Scan(&n)\n\n    quadrado(n)\n}\n",
